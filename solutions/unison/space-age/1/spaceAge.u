spaceAge.age : Text -> Nat -> Optional Float
spaceAge.age planet earthAgeSeconds =
  earthYearInSeconds = 31557600.0

  Abort.toOptional! do
    earthAge = fromNat earthAgeSeconds / earthYearInSeconds
    ratio = match planet with
      "Mercury" -> 0.2408467
      "Venus" -> 0.61519726
      "Earth" -> 1.0
      "Mars" -> 1.8808158
      "Jupiter" -> 11.862615
      "Saturn" -> 29.447498
      "Uranus" -> 84.016846
      "Neptune" -> 164.79132
      _ -> abort
    
    earthAge / ratio